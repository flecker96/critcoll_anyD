     -    2*d*du0dtau(j)*ia20B(j)**2 - 12*ia20(j)*u0B(j) + 
     -    10*d*ia20(j)*u0B(j) - 2*d**2*ia20(j)*u0B(j) + 
     -    12*d*ia20(j)*v0B(j) - 4*d**2*ia20(j)*v0B(j) + 
     -    24*ia20(j)*u0B(j)**2*v0B(j) - 
