      " ", "*)"}], "\n", 
     RowBox[{"dtsolNow", "=", 
      RowBox[{"D", "[", 
       RowBox[{"solNow", ",", "t"}], "]"}]}], ";", "\n", 
     RowBox[{"(*", " ", 
