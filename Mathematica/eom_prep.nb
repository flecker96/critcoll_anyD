      " ", "*)"}], "\n", 
     RowBox[{"solNow", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"Solve", "[", 
         RowBox[{
          RowBox[{"Thread", "[", 
           RowBox[{
            RowBox[{"eomNow", "[", 
             RowBox[{"[", 
              RowBox[{";;", 
               RowBox[{"-", "2"}]}], "]"}], "]"}], "==", "0"}], "]"}], ",", 
          RowBox[{"{", 
