Cell["\<\
        ((-3 + d)*ia21(j)**3*v0(j))/ia20(j)**4 - 
     -  ((-3 + d)*ia21(j)*
     -     (2*ia22(j)*v0(j) + 
     -       ia21(j)*((-1 + f1(j))*v0(j) + v1(j))))/
     -   ia20(j)**3 - ((-3 + d)*
     -     ((-1 + f1(j) - f2(j) + f3(j))*v0(j) + 
     -       (1 - f1(j) + f2(j))*v1(j) + (-1 + f1(j))*v2(j))
     -     )/ia20(j) + ((-2 + d)*
     -      (-1 + f1(j) - f2(j) + f3(j))*u0(j) - 
     -     (-2 + d)*(-1 + f1(j) - f2(j))*u1(j) + 2*u2(j) - 
     -     d*u2(j) - 2*f1(j)*u2(j) + d*f1(j)*u2(j) - 
     -     2*u3(j) + d*u3(j) + 2*v0(j) - d*v0(j) - 
     -     2*f1(j)*v0(j) + d*f1(j)*v0(j) + 2*f2(j)*v0(j) - 
     -     d*f2(j)*v0(j) - 2*f3(j)*v0(j) + d*f3(j)*v0(j) - 
     -     2*v1(j) + d*v1(j) + 2*f1(j)*v1(j) - 
     -     d*f1(j)*v1(j) - 2*f2(j)*v1(j) + d*f2(j)*v1(j) - 
     -     2*f3(j)*v1(j) + 
     -     ((-2 + d)*(-1 + f1(j)) - 4*f2(j))*v2(j))/2. + 
     -  ((-3 + d)*(ia23(j)*v0(j) + 
     -       ia22(j)*((-1 + f1(j))*v0(j) + v1(j)) + 
     -       ia21(j)*((1 - f1(j) + f2(j))*v0(j) + 
     -          (-1 + f1(j))*v1(j) + v2(j))))/ia20(j)**2\
\>", "Output",
