     -       2*x*dudtau(i)*fB(i)*ia2B(i)**2 - 
     -       (x + fB(i))*ia2B(i)*
     -        (2*lamb*x*ia2B(i) + 
     -          fB(i)*(2*(-3 + d) - (-2 + d)*ia2B(i)))*u(i) - 
     -       6*x*fB(i)*ia2(i)*uB(i) + 
     -       2*d*x*fB(i)*ia2(i)*uB(i) - 
     -       6*fB(i)**2*ia2(i)*uB(i) + 
