     -    24*ia20(j)*v0B(j)**3 - 44*d*ia20(j)*v0B(j)**3 + 
     -    30*d**2*ia20(j)*v0B(j)**3 - 
     -    9*d**3*ia20(j)*v0B(j)**3 + d**4*ia20(j)*v0B(j)**3 - 
     -    (-2 + d)*ia20B(j)*u0(j)*
     -     ((-6 + 3*d + 2*lamb)*ia20B(j) + 
     -       2*(-3 + d)*(-1 + (-2 + d)**2*u0B(j)*v0B(j))) - 
     -    ia20B(j)*v0(j)*
     -     (3*(-2 + d)**2*ia20B(j) + 
     -       (-3 + d)*(-4*d + (-2 + d)**3*u0B(j)**2 + 
     -          3*(-2 + d)**3*v0B(j)**2)) - 
     -    48*ia20(j)*v1B(j) + 16*d*ia20(j)*v1B(j))/
