Cell["\<\
        -0.0078125*((-3 + d)*(-2 + d)**3*
     -     (8*f0(j)*(-2*du1dtau(j)**2*f0(j) + 
     -          (2*(-1 + d)*df0dtau(j)*du1dtau(j) + 
     -             (-((-1 + d)*d2u1dtau2(j)) + 
     -                (1 - 3*d + 2*lamb - 2*d*lamb)*du1dtau(j)
     -                )*f0(j))*u1(j) + 
     -          (-1 + d)*df0dtau(j)*u1(j)**2) + 
     -       4*f0(j)*u1(j)*
     -        ((-5 + d)*(-2 + d)**3*(-1 + d)*f0(j)**3*
     -           u1(j)**3 + 
     -          2*(-1 + d)*df0dtau(j)*
     -           (du1dtau(j) + (2 + lamb)*u1(j)) + 
     -          2*f0(j)*(-((-1 + d)*d2u1dtau2(j)) + 
     -             (1 - 3*d - 2*lamb)*du1dtau(j) + 
     -             (2 + lamb + lamb**2 - 
     -                d*(4 + lamb*(3 + lamb)))*u1(j))) + 
     -       f0(j)*((-5 + d)*(-2 + d)**3*(-1 + d)*f0(j)**3*
     -           u1(j)**4 - 
     -          16*(-1 + d)*df0dtau(j)*u1(j)*
     -           (du1dtau(j) + u1(j)) + 
     -          8*f0(j)*(du1dtau(j)**2 + 
     -             ((-1 + d)*d2u1dtau2(j) + 
     -                (-1 + 3*d + (-1 + d)*lamb)*du1dtau(j))*
     -              u1(j) + 
     -             (-1 + 2*d + (-1 + d)*lamb)*u1(j)**2))))/
     -   ((-1 + d)**2*(1 + d)*f0(j)**3)\
