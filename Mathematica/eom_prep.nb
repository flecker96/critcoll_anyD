Cell["\<\
        (f0(j)*u1(j)*(-6*(-1 + d)*(1 + lamb)*
     -        df0dtau(j)**2 + 
     -       2*(-1 + d)*(1 + lamb)*
     -        (d2f0dtau2(j) + (7 + 3*lamb)*df0dtau(j))*f0(j)
     -         - 2*(-1 + d)*
     -        (6 + 11*lamb + 6*lamb**2 + lamb**3)*f0(j)**2\\
     -        + (-2 + d)**3*(3 - 7*d + 2*d**2)*f0(j)**4*
     -        u1(j)*(2*du1dtau(j) + (3 + lamb)*u1(j))) + 
     -    f0(j)*(-2*(-1 + d)*
     -        (3*(2 + lamb)*d2u1dtau2(j) + d3u1dtau3(j) + 
     -          (11 + 12*lamb + 3*lamb**2)*du1dtau(j))*
     -        f0(j)**2 + 
     -       (-2 + d)**3*(3 - 7*d + 2*d**2)*du1dtau(j)*
     -        f0(j)**4*u1(j)**2 - 
     -       6*(-1 + d)*df0dtau(j)*
     -        (3*df0dtau(j)*du1dtau(j) + 2*df0dtau(j)*u1(j))
     -         + 2*(-1 + d)*f0(j)*
     -        (6*d2u1dtau2(j)*df0dtau(j) + 
     -          d2f0dtau2(j)*du1dtau(j) + 
     -          10*df0dtau(j)*du1dtau(j) + 
     -          2*lamb*df0dtau(j)*du1dtau(j) + 
     -          (d2f0dtau2(j) + 2*(5 + 3*lamb)*df0dtau(j))*
     -           du1dtau(j) + 
     -          (d2f0dtau2(j) + (7 + 2*lamb)*df0dtau(j))*
     -           u1(j))) + 
     -    f0(j)*(30*(-1 + d)*df0dtau(j)**2*
     -        (du1dtau(j) + u1(j)) - 
     -       (-2 + d)**3*(3 - 7*d + 2*d**2)*f0(j)**4*
     -        u1(j)**2*(du1dtau(j) + u1(j)) + 
     -       2*(-1 + d)*f0(j)**2*
     -        (3*((6 + lamb)*d2u1dtau2(j) + d3u1dtau3(j)) + 
     -          (33 + 10*lamb + lamb**2)*du1dtau(j) + 
     -          (18 + 7*lamb + lamb**2)*u1(j)) - 
     -       4*(-1 + d)*f0(j)*
     -        (2*d2f0dtau2(j)*du1dtau(j) + 
     -          df0dtau(j)*
     -           (6*d2u1dtau2(j) + (20 + 3*lamb)*du1dtau(j))
     -            + (2*d2f0dtau2(j) + 
     -             (14 + 3*lamb)*df0dtau(j))*u1(j))))/
     -  (4.*(-1 + d)**2*(1 + d)*f0(j)**6)\
\>", "Output",
 CellChangeTimes->{
  3.9380833691057243`*^9, {3.938083638530096*^9, 3.938083694789809*^9}, {
   3.9380837414563103`*^9, 3.938083753971199*^9}, {3.938083873537313*^9, 
   3.938083920292183*^9}},
 CellLabel->
  "Out[136]//FortranForm=",ExpressionUUID->"ee5211b2-54b8-4f6e-8752-\
24a7440228f6"]
}, Open  ]],

