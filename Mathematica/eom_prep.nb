     RowBox[{"(*", " ", 
      RowBox[{"replacement", " ", "rule", " ", "for", " ", "derivatives"}], 
      " ", "*)"}], "\n", 
     RowBox[{"dtsolNow", "=", 
      RowBox[{"D", "[", 
       RowBox[{"solNow", ",", "t"}], "]"}]}], ";", "\n", 
     RowBox[{"(*", " ", 
      RowBox[{
