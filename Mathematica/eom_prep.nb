   RowBox[{
    RowBox[{
     RowBox[{"eomNow", "=", 
      RowBox[{"SeriesCoefficient", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"eomall0", "/.", "replser0"}], "/.", "replsol0"}], ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", "0", ",", "i"}], "}"}]}], "]"}]}], ";", "\n", 
     RowBox[{"(*", " ", 
      RowBox[{"solving", " ", "for", " ", "series", " ", "coefficients"}], 
      " ", "*)"}], "\n", 
     RowBox[{"solNow", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"Solve", "[", 
         RowBox[{
          RowBox[{"Thread", "[", 
           RowBox[{
            RowBox[{"eomNow", "[", 
             RowBox[{"[", 
              RowBox[{";;", 
               RowBox[{"-", "2"}]}], "]"}], "]"}], "==", "0"}], "]"}], ",", 
          RowBox[{"{", 
