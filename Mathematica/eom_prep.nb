     -        2*x*f(i)*ia2B(i)**2*uB(i) + 
     -        d*x*f(i)*ia2B(i)**2*uB(i) + 
     -        (x - fB(i))*ia2B(i)*
     -         (2*lamb*x*ia2B(i) + 
     -           fB(i)*(6 - 2*d + (-2 + d)*ia2B(i)))*v(i) - 
     -        6*x*fB(i)*ia2(i)*vB(i) + 
     -        2*d*x*fB(i)*ia2(i)*vB(i) + 
     -        6*fB(i)**2*ia2(i)*vB(i) - 
     -        2*d*fB(i)**2*ia2(i)*vB(i) + 
     -        6*x*f(i)*ia2B(i)*vB(i) - 
     -        2*d*x*f(i)*ia2B(i)*vB(i) - 
     -        2*x*f(i)*ia2B(i)**2*vB(i) + 
     -        d*x*f(i)*ia2B(i)**2*vB(i))/
     -      (x*(x - fB(i))**2*ia2B(i)**2))))\
