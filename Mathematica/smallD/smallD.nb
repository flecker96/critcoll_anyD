           RowBox[{
            FractionBox["1", "2"], "-", 
            RowBox[{"\[ImaginaryI]", " ", "k"}]}], ",", 
           RowBox[{"1", "-", 
            SuperscriptBox["r", "2"]}]}], "]"}]}]}], ")"}]}]}]}], 
