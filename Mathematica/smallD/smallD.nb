Cell[CellGroupData[{

Cell["Use 2F1 identities to get better expansion", "Subsubsection",
 CellChangeTimes->{{3.937542443317828*^9, 
  3.937542451719393*^9}},ExpressionUUID->"3fa5b932-2403-4d73-b909-\
602b5dad06eb"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"aa", "=", 
   RowBox[{"1", "+", 
    RowBox[{"I", " ", 
     RowBox[{"k", "/", "2"}]}]}]}], ";", 
  RowBox[{"bb", "=", 
   RowBox[{
    RowBox[{"1", "/", "2"}], "+", 
    RowBox[{"I", " ", 
     RowBox[{"k", "/", "2"}]}]}]}], ";", 
  RowBox[{"cc", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"Re", "[", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"Hypergeometric2F1", "[", 
         RowBox[{
          RowBox[{"1", "+", 
           FractionBox[
            RowBox[{"\[ImaginaryI]", " ", "k"}], "2"]}], ",", 
          RowBox[{
           FractionBox["1", "2"], " ", 
           RowBox[{"(", 
            RowBox[{"1", "+", 
             RowBox[{"\[ImaginaryI]", " ", "k"}]}], ")"}]}], ",", "1", ",", 
          SuperscriptBox["r", "2"]}], "]"}], "-", 
        RowBox[{
         RowBox[{"Gamma", "[", "cc", "]"}], 
         RowBox[{
          RowBox[{"Gamma", "[", 
           RowBox[{"cc", "-", "aa", "-", "bb"}], "]"}], "/", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Gamma", "[", 
             RowBox[{"cc", "-", "aa"}], "]"}], 
            RowBox[{"Gamma", "[", 
             RowBox[{"cc", "-", "bb"}], "]"}]}], ")"}]}], 
         RowBox[{"Hypergeometric2F1", "[", 
          RowBox[{"aa", ",", "bb", ",", 
           RowBox[{"aa", "+", "bb", "-", "cc", "+", "1"}], ",", 
           RowBox[{"1", "-", 
            SuperscriptBox["r", "2"]}]}], "]"}]}], "-", 
        RowBox[{
         RowBox[{"Gamma", "[", "cc", "]"}], 
         RowBox[{
          RowBox[{"Gamma", "[", 
           RowBox[{"aa", "+", "bb", "-", "cc"}], "]"}], "/", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Gamma", "[", "aa", "]"}], 
            RowBox[{"Gamma", "[", "bb", "]"}]}], ")"}]}], 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "-", 
            RowBox[{"r", "^", "2"}]}], ")"}], "^", 
          RowBox[{"(", 
           RowBox[{"cc", "-", "aa", "-", "bb"}], ")"}]}], 
         RowBox[{"Hypergeometric2F1", "[", 
          RowBox[{
           RowBox[{"cc", "-", "aa"}], ",", 
           RowBox[{"cc", "-", "bb"}], ",", 
           RowBox[{"cc", "-", "aa", "-", "bb", "+", "1"}], ",", 
           RowBox[{"1", "-", 
            SuperscriptBox["r", "2"]}]}], "]"}]}]}], "//", "FullSimplify"}], 
      ")"}], "/.", 
     RowBox[{"k", "->", "1"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"r", ",", "0", ",", "1"}], "}"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.9375417152740507`*^9, 3.937541989034874*^9}, {
  3.937542210487875*^9, 3.937542210972577*^9}},
 CellLabel->"In[61]:=",ExpressionUUID->"b55015be-e5e7-463f-8008-a62fbcf6d170"],

