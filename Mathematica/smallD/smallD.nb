         RowBox[{"\[ImaginaryI]", " ", "k"}]}], "]"}]}], 
      RowBox[{"Gamma", "[", 
       RowBox[{"1", "+", 
        RowBox[{"\[ImaginaryI]", " ", "k"}]}], "]"}]]}], ")"}]}], 
  RowBox[{"2", " ", 
   SqrtBox["\[Pi]"]}]]], "Output",
