Cell[BoxData[
 RowBox[{"replu0v0", "=", 
  RowBox[{
   RowBox[{"Solve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"PILO", "[", 
         RowBox[{"t", ",", "r"}], "]"}], "==", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"u0", "[", 
            RowBox[{"t", ",", "r"}], "]"}], "+", 
           RowBox[{"v0", "[", 
            RowBox[{"t", ",", "r"}], "]"}]}], ")"}], "/", 
         RowBox[{"(", 
          RowBox[{"2", "r"}], ")"}]}]}], ",", 
       RowBox[{
        RowBox[{"PSILO", "[", 
         RowBox[{"t", ",", "r"}], "]"}], "==", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"v0", "[", 
            RowBox[{"t", ",", "r"}], "]"}], "-", 
           RowBox[{"u0", "[", 
            RowBox[{"t", ",", "r"}], "]"}]}], ")"}], "/", 
         RowBox[{"(", 
          RowBox[{"2", 
           RowBox[{"r", "^", "2"}]}], ")"}]}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"u0", "[", 
        RowBox[{"t", ",", "r"}], "]"}], ",", 
       RowBox[{"v0", "[", 
        RowBox[{"t", ",", "r"}], "]"}]}], "}"}]}], "]"}], "[", 
   RowBox[{"[", "1", "]"}], "]"}]}]], "Input",
