Cell[BoxData[
 RowBox[{
  RowBox[{"(", 
   InterpretationBox[
    RowBox[{
     FractionBox[
      RowBox[{"\[ImaginaryI]", " ", 
       SuperscriptBox["2", 
        RowBox[{
         RowBox[{"-", "1"}], "-", 
         RowBox[{"\[ImaginaryI]", " ", "k"}]}]], " ", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"\[ImaginaryI]", " ", "k", " ", "t"}]], " ", 
       SqrtBox["\[Pi]"], " ", 
       TemplateBox[{"1"},
        "C"], " ", 
       RowBox[{"Sech", "[", 
        RowBox[{"k", " ", "\[Pi]"}], "]"}]}], 
      RowBox[{"k", " ", 
       RowBox[{"Gamma", "[", 
        RowBox[{
         RowBox[{"-", "1"}], "-", 
         RowBox[{"\[ImaginaryI]", " ", "k"}]}], "]"}], " ", 
       RowBox[{"Gamma", "[", 
        RowBox[{
         FractionBox["3", "2"], "+", 
         RowBox[{"\[ImaginaryI]", " ", "k"}]}], "]"}]}]], "-", 
     FractionBox[
      RowBox[{"\[ImaginaryI]", " ", 
       SuperscriptBox["2", 
        RowBox[{
         RowBox[{"-", "2"}], "-", 
         RowBox[{"\[ImaginaryI]", " ", "k"}]}]], " ", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"\[ImaginaryI]", " ", "k", " ", "t"}]], " ", 
       SqrtBox["\[Pi]"], " ", 
       TemplateBox[{"1"},
        "C"], " ", 
       RowBox[{"Sech", "[", 
        RowBox[{"k", " ", "\[Pi]"}], "]"}], " ", 
       RowBox[{"(", 
        RowBox[{"r", "-", "1"}], ")"}]}], 
      RowBox[{"k", " ", 
       RowBox[{"Gamma", "[", 
        RowBox[{
         RowBox[{"-", "3"}], "-", 
         RowBox[{"\[ImaginaryI]", " ", "k"}]}], "]"}], " ", 
       RowBox[{"Gamma", "[", 
        RowBox[{
         FractionBox["5", "2"], "+", 
         RowBox[{"\[ImaginaryI]", " ", "k"}]}], "]"}]}]], "+", 
     InterpretationBox[
      SuperscriptBox[
       RowBox[{"O", "[", 
        RowBox[{"r", "-", "1"}], "]"}], 
       RowBox[{"3", "/", "2"}]],
      SeriesData[$CellContext`r, 1, {}, 0, 3, 2],
      Editable->False]}],
    SeriesData[$CellContext`r, 1, {
     Complex[0, 1] 2^(-1 + Complex[0, -1] $CellContext`k) 
      E^(Complex[0, 1] $CellContext`k $CellContext`t) $CellContext`k^(-1) 
      Pi^Rational[1, 2] C[1] Gamma[-1 + Complex[0, -1] $CellContext`k]^(-1) 
      Gamma[Rational[3, 2] + Complex[0, 1] $CellContext`k]^(-1) 
      Sech[$CellContext`k Pi], 0, Complex[0, -1] 
      2^(-2 + Complex[0, -1] $CellContext`k) 
      E^(Complex[0, 1] $CellContext`k $CellContext`t) $CellContext`k^(-1) 
      Pi^Rational[1, 2] C[1] Gamma[-3 + Complex[0, -1] $CellContext`k]^(-1) 
      Gamma[Rational[5, 2] + Complex[0, 1] $CellContext`k]^(-1) 
      Sech[$CellContext`k Pi]}, 0, 3, 2],
    Editable->False], ")"}], "+", 
  RowBox[{
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "+", "r"}], ")"}], 
    RowBox[{
     RowBox[{"-", "\[ImaginaryI]"}], " ", "k"}]], " ", 
   RowBox[{"(", 
    InterpretationBox[
     RowBox[{
      FractionBox[
       RowBox[{
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{
          RowBox[{"-", "k"}], " ", 
          RowBox[{"(", 
           RowBox[{"\[Pi]", "-", 
            RowBox[{"\[ImaginaryI]", " ", "t"}]}], ")"}]}]], " ", 
        SqrtBox[
         FractionBox["\[Pi]", "2"]], " ", 
        TemplateBox[{"1"},
         "C"], " ", 
        RowBox[{"Sech", "[", 
         RowBox[{"k", " ", "\[Pi]"}], "]"}]}], 
       RowBox[{"k", " ", 
        RowBox[{"Gamma", "[", 
         RowBox[{
          FractionBox["1", "2"], "-", 
          RowBox[{"\[ImaginaryI]", " ", "k"}]}], "]"}], " ", 
        RowBox[{"Gamma", "[", 
         RowBox[{"\[ImaginaryI]", " ", "k"}], "]"}], " ", 
        SqrtBox[
         RowBox[{"r", "-", "1"}]]}]], "-", 
      FractionBox[
       RowBox[{
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{
          RowBox[{"-", "k"}], " ", 
          RowBox[{"(", 
           RowBox[{"\[Pi]", "-", 
            RowBox[{"\[ImaginaryI]", " ", "t"}]}], ")"}]}]], " ", 
        SqrtBox[
         RowBox[{"2", " ", "\[Pi]"}]], " ", 
        TemplateBox[{"1"},
         "C"], " ", 
        RowBox[{"Sech", "[", 
         RowBox[{"k", " ", "\[Pi]"}], "]"}], " ", 
        SqrtBox[
         RowBox[{"r", "-", "1"}]]}], 
       RowBox[{"k", " ", 
        RowBox[{"Gamma", "[", 
         RowBox[{
          FractionBox["1", "2"], "-", 
          RowBox[{"\[ImaginaryI]", " ", "k"}]}], "]"}], " ", 
        RowBox[{"Gamma", "[", 
         RowBox[{"\[ImaginaryI]", " ", "k"}], "]"}]}]], "+", 
      InterpretationBox[
       SuperscriptBox[
        RowBox[{"O", "[", 
         RowBox[{"r", "-", "1"}], "]"}], 
        RowBox[{"3", "/", "2"}]],
       SeriesData[$CellContext`r, 1, {}, -1, 3, 2],
       Editable->False]}],
     SeriesData[$CellContext`r, 1, {
      E^((-$CellContext`k) (Pi + 
          Complex[0, -1] $CellContext`t)) $CellContext`k^(-1) (Rational[1, 2] 
         Pi)^Rational[1, 2] C[1] 
       Gamma[Rational[1, 2] + Complex[0, -1] $CellContext`k]^(-1) 
