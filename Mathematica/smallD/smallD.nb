Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"v016", "[", 
    RowBox[{"t_", ",", "r_"}], "]"}], "=", 
   RowBox[{"Normal", "[", 
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Series", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"v0sol", "[", 
             RowBox[{"t", ",", "r"}], "]"}], "/.", 
            RowBox[{"k", "->", 
             RowBox[{"n", " ", "k"}]}]}], ")"}], "-", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"v0sol", "[", 
             RowBox[{"t", ",", "r"}], "]"}], "/.", 
            RowBox[{"k", "->", 
             RowBox[{
              RowBox[{"-", "n"}], " ", "k"}]}]}], ")"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"r", ",", "0", ",", "10"}], "}"}]}], "]"}], "/.", 
       RowBox[{
        TemplateBox[{"1"},
         "C"], "->", 
        RowBox[{
         RowBox[{
          RowBox[{"cu", "[", "n", "]"}], "/", "2"}], "/", "I"}]}]}], ",", 
      RowBox[{"{", 
       RowBox[{"n", ",", "1", ",", "16"}], "}"}]}], "]"}], "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.93753497068134*^9, 3.9375349830598183`*^9}, 
   3.93753507789261*^9, {3.937535148536421*^9, 3.9375351560515003`*^9}, {
   3.937536343419228*^9, 3.937536357929584*^9}, {3.937958955710566*^9, 
   3.937958959166033*^9}},
 CellLabel->
  "In[165]:=",ExpressionUUID->"41f1b931-2750-46a7-aa86-d4ec65b1b8fb"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Show that solutions fail to be regular at r=1 (if k is real), though u0 is \
regular\
\>", "Section",
 CellChangeTimes->{{3.937529747621255*^9, 3.9375297601804647`*^9}, {
  3.9375300061815767`*^9, 3.93753001181246*^9}, {3.937530064247407*^9, 
  3.937530064453096*^9}, {3.9375301066451797`*^9, 3.9375301090772953`*^9}, {
  3.93753107474905*^9, 
  3.937531080470188*^9}},ExpressionUUID->"82ad9469-83cb-46fd-af0b-\
d2232b28b134"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Assuming", "[", 
  RowBox[{
   RowBox[{"r", "<", "1"}], ",", 
   RowBox[{
    RowBox[{"Series", "[", 
     RowBox[{
      RowBox[{"pisol", "[", "r", "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"r", ",", "1", ",", "1"}], "}"}]}], "]"}], "//", 
    "FullSimplify"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.9375297637642117`*^9, 3.9375298283083267`*^9}, {
  3.93752989095368*^9, 3.9375299577174253`*^9}},
 CellLabel->"In[98]:=",ExpressionUUID->"74bbdbe1-2833-4d69-8e46-7936fc49cf27"],

Cell[BoxData[
 RowBox[{
  InterpretationBox[
   SuperscriptBox[
    RowBox[{"O", "[", 
     RowBox[{"r", "-", "1"}], "]"}], "0"],
   SeriesData[$CellContext`r, 1, {}, 0, 0, 1],
   Editable->False], "+", 
  RowBox[{
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "+", "r"}], ")"}], 
    RowBox[{
     RowBox[{"-", "\[ImaginaryI]"}], " ", "k"}]], " ", 
   RowBox[{"(", 
    InterpretationBox[
     RowBox[{
      FractionBox[
       RowBox[{
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{
          RowBox[{"-", "k"}], " ", 
          RowBox[{"(", 
           RowBox[{"\[Pi]", "-", 
            RowBox[{"\[ImaginaryI]", " ", "t"}]}], ")"}]}]], " ", 
        SqrtBox[
         FractionBox["\[Pi]", "2"]], " ", 
        TemplateBox[{"1"},
         "C"], " ", 
        RowBox[{"Sech", "[", 
         RowBox[{"k", " ", "\[Pi]"}], "]"}]}], 
       RowBox[{"k", " ", 
        RowBox[{"Gamma", "[", 
         RowBox[{
          FractionBox["1", "2"], "-", 
          RowBox[{"\[ImaginaryI]", " ", "k"}]}], "]"}], " ", 
        RowBox[{"Gamma", "[", 
         RowBox[{"\[ImaginaryI]", " ", "k"}], "]"}], " ", 
        SqrtBox[
         RowBox[{"r", "-", "1"}]]}]], "+", 
      InterpretationBox[
       SqrtBox[
        RowBox[{"O", "[", 
         RowBox[{"r", "-", "1"}], "]"}]],
       SeriesData[$CellContext`r, 1, {}, -1, 1, 2],
       Editable->False]}],
     SeriesData[$CellContext`r, 1, {
      E^((-$CellContext`k) (Pi + 
          Complex[0, -1] $CellContext`t)) $CellContext`k^(-1) (Rational[1, 2] 
         Pi)^Rational[1, 2] C[1] 
       Gamma[Rational[1, 2] + Complex[0, -1] $CellContext`k]^(-1) 
       Gamma[Complex[0, 1] $CellContext`k]^(-1) Sech[$CellContext`k Pi]}, -1, 
      1, 2],
     Editable->False], ")"}]}]}]], "Output",
 CellChangeTimes->{{3.937529780005842*^9, 3.937529829033392*^9}, {
   3.937529896912766*^9, 3.937529958159916*^9}, 3.937532090250587*^9, 
   3.937535539453108*^9, 3.937958332608515*^9},
 CellLabel->"Out[98]=",ExpressionUUID->"ad03179b-2b72-46b3-a6f7-6b197f58b52a"]
}, Open  ]],

