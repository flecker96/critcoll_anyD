Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Collect", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"Expand", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Assuming", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"r", "<", "1"}], ",", 
            RowBox[{"k", ">", "0"}], ",", 
            RowBox[{"t", ">", "0"}]}], "}"}], ",", 
          RowBox[{
           RowBox[{"Normal", "[", 
            RowBox[{"Series", "[", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{"v0solSSH", "[", 
                 RowBox[{"t", ",", "r"}], "]"}], "-", 
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"v0solSSH", "[", 
                   RowBox[{"t", ",", "r"}], "]"}], "/.", 
                  RowBox[{"k", "->", 
                   RowBox[{"-", "k"}]}]}], ")"}]}], "/.", " ", 
               RowBox[{
                TemplateBox[{"1"},
                 "C"], "->", 
                RowBox[{
                 RowBox[{"cu", "[", "1", "]"}], "/", 
                 RowBox[{"(", 
                  RowBox[{"2", "I"}], ")"}]}]}]}], ",", 
              RowBox[{"{", 
               RowBox[{"r", ",", "1", ",", "1"}], "}"}]}], "]"}], "]"}], "//",
            "Simplify"}]}], "]"}], "/.", 
        RowBox[{
         RowBox[{"+", 
          FractionBox[
           RowBox[{
            SuperscriptBox["2", 
             RowBox[{
              RowBox[{"-", "\[ImaginaryI]"}], " ", "k"}]], " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"-", 
               FractionBox[
                RowBox[{
                 SuperscriptBox["\[ExponentialE]", 
                  RowBox[{"2", " ", "\[ImaginaryI]", " ", "k", " ", "t"}]], 
                 " ", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{
                    RowBox[{"-", "3"}], " ", "\[ImaginaryI]"}], "+", 
                   RowBox[{"2", " ", "k"}]}], ")"}], " ", 
                 RowBox[{"Gamma", "[", 
                  RowBox[{
                   RowBox[{"-", 
                    FractionBox["3", "2"]}], "-", 
                   RowBox[{"\[ImaginaryI]", " ", "k"}]}], "]"}]}], 
                RowBox[{"Gamma", "[", 
                 RowBox[{
                  RowBox[{"-", "\[ImaginaryI]"}], " ", "k"}], "]"}]]}], "+", 
              FractionBox[
               RowBox[{
                SuperscriptBox["2", 
                 RowBox[{"2", " ", "\[ImaginaryI]", " ", "k"}]], " ", 
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"3", " ", "\[ImaginaryI]"}], "+", 
                  RowBox[{"2", " ", "k"}]}], ")"}], " ", 
                RowBox[{"Gamma", "[", 
                 RowBox[{
                  RowBox[{"-", 
                   FractionBox["3", "2"]}], "+", 
                  RowBox[{"\[ImaginaryI]", " ", "k"}]}], "]"}]}], 
               RowBox[{"Gamma", "[", 
                RowBox[{"\[ImaginaryI]", " ", "k"}], "]"}]]}], ")"}]}], 
           "k"]}], "->", "0"}]}], "/.", 
       RowBox[{
        RowBox[{"cu", "[", "1", "]"}], "->", "1"}]}], "]"}], "/.", 
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{" ", 
        RowBox[{"\[ImaginaryI]", " ", "k", " ", "t"}]}]], "->", 
      RowBox[{
       RowBox[{"Cos", "[", 
        RowBox[{"k", " ", "t"}], "]"}], "+", 
       RowBox[{"I", " ", 
        RowBox[{"Sin", "[", 
         RowBox[{"k", " ", "t"}], "]"}]}]}]}]}], "/.", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", "\[ImaginaryI]"}], " ", "k", " ", "t"}]], "->", 
     RowBox[{
      RowBox[{"Cos", "[", 
       RowBox[{"k", " ", "t"}], "]"}], "-", " ", 
      RowBox[{"I", " ", 
       RowBox[{"Sin", "[", 
        RowBox[{"k", " ", "t"}], "]"}]}]}]}]}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Sin", "[", 
      RowBox[{"k", " ", "t"}], "]"}], ",", " ", 
     RowBox[{"Cos", "[", 
      RowBox[{"k", " ", "t"}], "]"}]}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.937566333314246*^9, 3.937566402678072*^9}, {
  3.937566449411725*^9, 3.937566458038764*^9}, {3.9375665002056932`*^9, 
