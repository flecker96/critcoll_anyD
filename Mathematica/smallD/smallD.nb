  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "the", " ", "difference", " ", "between", " ", "the", " ", "boundary", 
     " ", "mode", " ", "and", " ", "the", " ", "exact", " ", "solution", " ", 
     "indeed", " ", "vanishes", " ", "at", " ", "the", " ", "SSH", " ", "but",
