Cell[CellGroupData[{

Cell["\<\
Here is the full solution for v0[t,r] with all Fourier modes, Taylor expanded \
around the origin to 10 orders\
\>", "Subsubsection",
 CellChangeTimes->{
  3.937535486451972*^9},ExpressionUUID->"4ad9fec5-0006-493c-a89e-\
f99249cbe7bb"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"v0origin", "[", 
   RowBox[{"t_", ",", "r_"}], "]"}], "=", 
  RowBox[{"Normal", "[", 
   RowBox[{"Sum", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"Series", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"v0sol", "[", "r", "]"}], "/.", 
             RowBox[{"k", "->", 
              RowBox[{"n", " ", "k"}]}]}], ")"}], "-", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"v0sol", "[", "r", "]"}], "/.", 
             RowBox[{"k", "->", 
              RowBox[{
               RowBox[{"-", "n"}], " ", "k"}]}]}], ")"}]}], "//", 
          "Simplify"}], ",", 
         RowBox[{"{", 
          RowBox[{"r", ",", "0", ",", "10"}], "}"}]}], "]"}], "/.", 
       RowBox[{
        TemplateBox[{"1"},
         "C"], "->", 
        RowBox[{
         RowBox[{
          RowBox[{"cu", "[", "n", "]"}], "/", "2"}], "/", "I"}]}]}], "//", 
      "FullSimplify"}], ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "1", ",", "Infinity"}], "}"}]}], "]"}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.937533937475371*^9, 3.9375339430273523`*^9}},
 CellLabel->"In[93]:=",ExpressionUUID->"c6b41276-7a9f-4c77-9104-c8cb018cc470"],

Cell[BoxData["0"], "Output",
 CellChangeTimes->{3.937534202288006*^9, 3.937535479690069*^9, 
