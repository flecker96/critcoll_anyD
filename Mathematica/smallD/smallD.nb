  RowBox[{"(*", " ", 
   RowBox[{
   "show", " ", "that", " ", "hypergeometric", " ", "trafo", " ", "used", " ",
     "above", " ", "indeed", " ", "works", " ", "as", " ", "an", " ", 
    "identity", " ", "in", " ", "the", " ", "whole", " ", "plane", " ", "but",
