         RowBox[{"\[ImaginaryI]", " ", "k"}]}], "]"}]}], 
      RowBox[{
       SqrtBox[
        RowBox[{"2", " ", "\[Pi]"}]], " ", 
       RowBox[{"Gamma", "[", 
        RowBox[{"1", "-", 
         RowBox[{"\[ImaginaryI]", " ", "k"}]}], "]"}]}]], "-", 
     FractionBox[
      RowBox[{"\[ImaginaryI]", " ", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"1", "-", "r"}], ")"}], 
        RowBox[{
         RowBox[{"-", 
          FractionBox["1", "2"]}], "-", 
         RowBox[{"\[ImaginaryI]", " ", "k"}]}]], " ", 
       RowBox[{"Gamma", "[", 
        RowBox[{
         FractionBox["1", "2"], "+", 
         RowBox[{"\[ImaginaryI]", " ", "k"}]}], "]"}]}], 
      RowBox[{
       SqrtBox[
        RowBox[{"2", " ", "\[Pi]"}]], " ", 
       RowBox[{"Gamma", "[", 
        RowBox[{"1", "+", 
         RowBox[{"\[ImaginaryI]", " ", "k"}]}], "]"}]}]]}], ")"}]}], "+", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     FractionBox[
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"1", "-", "r"}], ")"}], 
        RowBox[{
         RowBox[{"-", 
          FractionBox["1", "2"]}], "+", 
         RowBox[{"\[ImaginaryI]", " ", "k"}]}]], " ", 
       RowBox[{"Gamma", "[", 
        RowBox[{
         FractionBox["1", "2"], "-", 
         RowBox[{"\[ImaginaryI]", " ", "k"}]}], "]"}]}], 
      RowBox[{
       SqrtBox[
        RowBox[{"2", " ", "\[Pi]"}]], " ", 
       RowBox[{"Gamma", "[", 
        RowBox[{"1", "-", 
         RowBox[{"\[ImaginaryI]", " ", "k"}]}], "]"}]}]], "+", 
     FractionBox[
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"1", "-", "r"}], ")"}], 
        RowBox[{
         RowBox[{"-", 
          FractionBox["1", "2"]}], "-", 
         RowBox[{"\[ImaginaryI]", " ", "k"}]}]], " ", 
       RowBox[{"Gamma", "[", 
        RowBox[{
         FractionBox["1", "2"], "+", 
         RowBox[{"\[ImaginaryI]", " ", "k"}]}], "]"}]}], 
      RowBox[{
       SqrtBox[
        RowBox[{"2", " ", "\[Pi]"}]], " ", 
       RowBox[{"Gamma", "[", 
        RowBox[{"1", "+", 
         RowBox[{"\[ImaginaryI]", " ", "k"}]}], "]"}]}]]}], ")"}], " ", 
   RowBox[{"Sin", "[", 
    RowBox[{"k", " ", "t"}], "]"}]}]}]], "Output",
