Cell[BoxData[
 RowBox[{
  FractionBox["1", 
   RowBox[{"k", " ", 
    SqrtBox["\[Pi]"]}]], 
  SuperscriptBox["2", 
   RowBox[{
    RowBox[{"-", "2"}], "-", 
    RowBox[{"\[ImaginaryI]", " ", "k"}]}]], " ", 
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{"\[ImaginaryI]", " ", "k", " ", "t"}]], " ", 
  TemplateBox[{"1"},
   "C"], " ", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{
     FractionBox["1", 
      RowBox[{"Gamma", "[", 
       RowBox[{
        RowBox[{"-", "\[ImaginaryI]"}], " ", "k"}], "]"}]], 
     RowBox[{"\[ImaginaryI]", " ", 
      RowBox[{"Gamma", "[", 
       RowBox[{
        RowBox[{"-", 
         FractionBox["3", "2"]}], "-", 
        RowBox[{"\[ImaginaryI]", " ", "k"}]}], "]"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"3", " ", "\[ImaginaryI]"}], "-", 
           RowBox[{"2", " ", "k"}]}], ")"}], " ", 
         RowBox[{"(", 
          RowBox[{"\[ImaginaryI]", "+", 
           RowBox[{"k", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"-", "1"}], "+", "r"}], ")"}]}]}], ")"}], " ", 
         RowBox[{"Hypergeometric2F1", "[", 
          RowBox[{
           RowBox[{"1", "+", 
            FractionBox[
             RowBox[{"\[ImaginaryI]", " ", "k"}], "2"]}], ",", 
           RowBox[{
            FractionBox["1", "2"], " ", 
            RowBox[{"(", 
             RowBox[{"1", "+", 
              RowBox[{"\[ImaginaryI]", " ", "k"}]}], ")"}]}], ",", 
           RowBox[{
            FractionBox["3", "2"], "+", 
            RowBox[{"\[ImaginaryI]", " ", "k"}]}], ",", 
           RowBox[{"1", "-", 
            SuperscriptBox["r", "2"]}]}], "]"}]}], "+", 
        RowBox[{
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "\[ImaginaryI]"}], "+", "k"}], ")"}], "2"], " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], "+", 
           SuperscriptBox["r", "2"]}], ")"}], " ", 
         RowBox[{"Hypergeometric2F1", "[", 
          RowBox[{
           RowBox[{"1", "+", 
            FractionBox[
             RowBox[{"\[ImaginaryI]", " ", "k"}], "2"]}], ",", 
           RowBox[{
            FractionBox["1", "2"], " ", 
            RowBox[{"(", 
             RowBox[{"3", "+", 
              RowBox[{"\[ImaginaryI]", " ", "k"}]}], ")"}]}], ",", 
           RowBox[{
            FractionBox["5", "2"], "+", 
            RowBox[{"\[ImaginaryI]", " ", "k"}]}], ",", 
           RowBox[{"1", "-", 
            SuperscriptBox["r", "2"]}]}], "]"}]}]}], ")"}]}]}], "-", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"Gamma", "[", 
       RowBox[{"1", "+", 
        RowBox[{"\[ImaginaryI]", " ", "k"}]}], "]"}]], 
     RowBox[{
      SuperscriptBox["4", 
       RowBox[{"1", "+", 
        RowBox[{"\[ImaginaryI]", " ", "k"}]}]], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"1", "-", 
         SuperscriptBox["r", "2"]}], ")"}], 
       RowBox[{
        RowBox[{"-", 
         FractionBox["1", "2"]}], "-", 
        RowBox[{"\[ImaginaryI]", " ", "k"}]}]], " ", 
      RowBox[{"Gamma", "[", 
       RowBox[{
        FractionBox["1", "2"], "+", 
        RowBox[{"\[ImaginaryI]", " ", "k"}]}], "]"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"\[ImaginaryI]", "-", 
           RowBox[{"2", " ", "k"}]}], ")"}], " ", 
         RowBox[{"Hypergeometric2F1", "[", 
          RowBox[{
           RowBox[{"-", 
            FractionBox[
             RowBox[{"\[ImaginaryI]", " ", "k"}], "2"]}], ",", 
           RowBox[{
            RowBox[{"-", 
             FractionBox["1", "2"]}], " ", "\[ImaginaryI]", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"-", "\[ImaginaryI]"}], "+", "k"}], ")"}]}], ",", 
           RowBox[{
            RowBox[{"-", 
             FractionBox["1", "2"]}], "-", 
            RowBox[{"\[ImaginaryI]", " ", "k"}]}], ",", 
           RowBox[{"1", "-", 
            SuperscriptBox["r", "2"]}]}], "]"}]}], "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "\[ImaginaryI]"}], "+", "k", "-", 
           RowBox[{"k", " ", "r"}]}], ")"}], " ", 
