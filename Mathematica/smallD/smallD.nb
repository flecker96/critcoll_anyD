 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "...", " ", "but", " ", "the", " ", "near", " ", "SSH", " ", "expansion", 
    " ", "still", " ", "yields", " ", "a", " ", "term", " ", "that", " ", 
    "blows", " ", "up", " ", "like", " ", 
