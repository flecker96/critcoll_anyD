Cell[CellGroupData[{

Cell["Near SSH expansion (tricky!)", "Subsubsection",
 CellChangeTimes->{{3.937541386759013*^9, 
  3.937541391703246*^9}},ExpressionUUID->"4888fb60-f5f8-42b4-8e9e-\
162813d35d55"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
     "the", " ", "near", " ", "SSH", " ", "expansion", " ", "is", " ", 
      "wrong", " ", "as", " ", "we", " ", "shall", " ", "see", " ", "from", 
      " ", "the", " ", "plots", " ", "below"}], ";", " ", 
     RowBox[{
      RowBox[{"this", " ", "makes", " ", "sense", " ", "since", " ", "r"}], 
      "=", 
      RowBox[{
      "1", " ", "is", " ", "a", " ", "branch", " ", "point", " ", "of", " ", 
       "2", "F1"}]}]}], ",", " ", 
    RowBox[{
    "so", " ", "we", " ", "must", " ", "not", " ", "Taylor", " ", 
     "expand"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"u0modessh", "[", 
    RowBox[{"t_", ",", "r_"}], "]"}], "=", 
   RowBox[{"Normal", "[", 
    RowBox[{"Assuming", "[", 
     RowBox[{
      RowBox[{"r", "<", "1"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"Series", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"u0sol", "[", 
              RowBox[{"t", ",", "r"}], "]"}], ")"}], "-", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"u0sol", "[", 
               RowBox[{"t", ",", "r"}], "]"}], "/.", 
              RowBox[{"k", "->", 
               RowBox[{"-", "k"}]}]}], ")"}]}], "//", "Simplify"}], ",", 
          RowBox[{"{", 
           RowBox[{"r", ",", "1", ",", "2"}], "}"}]}], "]"}], "/.", 
        RowBox[{
         TemplateBox[{"1"},
          "C"], "->", 
         RowBox[{
          RowBox[{
           RowBox[{"cu", "[", "1", "]"}], "/", "2"}], "/", "I"}]}]}], "//", 
       "FullSimplify"}]}], "]"}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.9375328489193563`*^9, 3.937532893238282*^9}, {
  3.93753295724081*^9, 3.937532957971678*^9}, {3.937533058136311*^9, 
  3.937533061527725*^9}, {3.937533156963525*^9, 3.937533163926828*^9}, {
  3.9375400406178703`*^9, 3.937540042662918*^9}, {3.937540584747542*^9, 
  3.937540610917018*^9}, {3.937541534888082*^9, 3.937541557959797*^9}, {
  3.937561733505884*^9, 3.937561734417416*^9}},
