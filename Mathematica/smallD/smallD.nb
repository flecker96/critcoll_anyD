Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "adding", " ", "the", " ", "boundary", " ", "mode", " ", "to", " ", "the", 
    " ", "WRONG", " ", "SSH", " ", "expansion", " ", "gives", " ", "actually",
     " ", "a", " ", "somewhat", " ", "decent", " ", "approximation", " ", 
    "for", " ", "the", " ", "function", " ", "u0", " ", "close", " ", "to", 
    " ", "the", " ", "SSH"}], " ", "*)"}], " ", "\[IndentingNewLine]", 
  RowBox[{"Plot3D", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Re", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"SSHmode", "[", 
         RowBox[{"t", ",", "r"}], "]"}], "/.", 
        RowBox[{"k", "->", "1"}]}], "/.", 
       RowBox[{
        RowBox[{"cu", "[", "1", "]"}], "->", "1"}]}], "]"}], "+", 
     RowBox[{"Re", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"u0modessh", "[", 
         RowBox[{"t", ",", "r"}], "]"}], "/.", 
        RowBox[{"k", "->", "1"}]}], "/.", 
       RowBox[{
        RowBox[{"cu", "[", "1", "]"}], "->", "1"}]}], " ", "]"}], "-", 
     RowBox[{"Re", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"u0sol", "[", 
           RowBox[{"t", ",", "r"}], "]"}], "/.", 
          RowBox[{"k", "->", "1"}]}], ")"}], "-", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"u0sol", "[", 
           RowBox[{"t", ",", "r"}], "]"}], "/.", 
          RowBox[{"k", "->", 
           RowBox[{"-", "1"}]}]}], ")"}]}], "/.", " ", 
       RowBox[{
        TemplateBox[{"1"},
         "C"], " ", "->", 
        RowBox[{
         RowBox[{"1", "/", "2"}], "/", "I"}]}]}], "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", 
      RowBox[{"2", "Pi"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"r", ",", "0.99", ",", "1"}], "}"}], ",", 
    RowBox[{"PlotRange", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "0.01"}], ",", "0.01"}], "}"}]}]}], "]"}]}]], "Input",
