      RowBox[{"360", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "3044"}], "+", 
         RowBox[{"1869", " ", 
          SuperscriptBox["k", "2"]}], "-", 
         RowBox[{"126", " ", 
          SuperscriptBox["k", "4"]}], "+", 
         SuperscriptBox["k", "6"]}], ")"}], " ", 
       SuperscriptBox["r", "7"]}], "+", 
      RowBox[{
       RowBox[{"(", 
