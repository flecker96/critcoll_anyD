Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"USSH16", "[", "t_", "]"}], "=", 
   RowBox[{"Sum", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"SSHmode", "[", 
       RowBox[{"t", ",", "r"}], "]"}], "/.", 
      RowBox[{
       RowBox[{"cu", "[", "1", "]"}], "->", 
       RowBox[{"cu", "[", "n", "]"}]}]}], ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "1", ",", "16"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.937562804321669*^9, 3.937562875939209*^9}},
 CellLabel->"In[74]:=",ExpressionUUID->"e1af8bbf-d8ab-4c9e-82c0-93b9e3703845"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Plot real and imaginary parts of u0 near the SSH and show that imaginary part \
vanishes\
\>", "Subsubsection",
 CellChangeTimes->{{3.937533325362658*^9, 
  3.937533348900091*^9}},ExpressionUUID->"a84a1325-c723-4eea-9b7c-\
158737233c30"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "this", " ", "is", " ", "the", " ", "plot", " ", "of", " ", "the", " ", 
    "WRONG", " ", "expansion", " ", "near", " ", "SSH"}], " ", "*)"}], " ", 
  "\[IndentingNewLine]", 
  RowBox[{"Plot3D", "[", 
   RowBox[{
    RowBox[{"Re", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"u0modessh", "[", 
        RowBox[{"t", ",", "r"}], "]"}], "/.", 
       RowBox[{"k", "->", "1"}]}], "/.", 
      RowBox[{
       RowBox[{"cu", "[", "1", "]"}], "->", "1"}]}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", 
      RowBox[{"2", "Pi"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"r", ",", "0.9", ",", "1"}], "}"}]}], "]"}]}]], "Input",
