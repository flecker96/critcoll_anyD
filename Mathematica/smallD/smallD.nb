Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"u0sol", "[", 
  RowBox[{"t", ",", "r"}], "]"}]], "Input",
 CellChangeTimes->{{3.937958915549549*^9, 3.937958919801516*^9}},
 CellLabel->
  "In[164]:=",ExpressionUUID->"5d5585fb-b919-4618-84eb-f603b296f936"],

Cell[BoxData[
 RowBox[{
  FractionBox["1", "k"], 
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{"\[ImaginaryI]", " ", "k", " ", "t"}]], " ", 
  TemplateBox[{"1"},
   "C"], " ", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "\[ImaginaryI]"}], "+", "k", "+", 
       RowBox[{"k", " ", "r"}]}], ")"}], " ", 
     RowBox[{"Hypergeometric2F1", "[", 
      RowBox[{
       RowBox[{"1", "+", 
        FractionBox[
         RowBox[{"\[ImaginaryI]", " ", "k"}], "2"]}], ",", 
       RowBox[{
        FractionBox["1", "2"], " ", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"\[ImaginaryI]", " ", "k"}]}], ")"}]}], ",", "1", ",", 
       SuperscriptBox["r", "2"]}], "]"}]}], "+", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "\[ImaginaryI]"}], "+", "k"}], ")"}], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "1"}], "+", 
       SuperscriptBox["r", "2"]}], ")"}], " ", 
     RowBox[{"Hypergeometric2F1", "[", 
      RowBox[{
       RowBox[{"1", "+", 
        FractionBox[
         RowBox[{"\[ImaginaryI]", " ", "k"}], "2"]}], ",", 
       RowBox[{
        FractionBox["1", "2"], " ", 
        RowBox[{"(", 
         RowBox[{"3", "+", 
          RowBox[{"\[ImaginaryI]", " ", "k"}]}], ")"}]}], ",", "1", ",", 
       SuperscriptBox["r", "2"]}], "]"}]}]}], ")"}]}]], "Output",
 CellChangeTimes->{3.937958920444942*^9},
 CellLabel->
  "Out[164]=",ExpressionUUID->"05cea392-bc3b-4c98-b06e-fc3c5091c27b"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Here is the full solution for u0[t,r] with all Fourier modes, Taylor expanded \
around the origin to 10 orders\
\>", "Subsubsection",
 CellChangeTimes->{{3.9375337158313007`*^9, 
  3.937533746837208*^9}},ExpressionUUID->"d0037ea5-7231-4737-a3ab-\
92d0d8b76532"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"u0origin", "[", 
   RowBox[{"t_", ",", "r_"}], "]"}], "=", 
  RowBox[{"Normal", "[", 
   RowBox[{"Sum", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"Series", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"u0sol", "[", "r", "]"}], "/.", 
             RowBox[{"k", "->", 
              RowBox[{"n", " ", "k"}]}]}], ")"}], "-", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"u0sol", "[", "r", "]"}], "/.", 
             RowBox[{"k", "->", 
              RowBox[{
               RowBox[{"-", "n"}], " ", "k"}]}]}], ")"}]}], "//", 
          "Simplify"}], ",", 
         RowBox[{"{", 
          RowBox[{"r", ",", "0", ",", "10"}], "}"}]}], "]"}], "/.", 
       RowBox[{
        TemplateBox[{"1"},
         "C"], "->", 
        RowBox[{
         RowBox[{
          RowBox[{"cu", "[", "n", "]"}], "/", "2"}], "/", "I"}]}]}], "//", 
      "FullSimplify"}], ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "1", ",", "Infinity"}], "}"}]}], "]"}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.937533628583167*^9, 3.9375336934602547`*^9}, {
  3.937533752071608*^9, 3.937533785624422*^9}},
 CellLabel->"In[85]:=",ExpressionUUID->"f06e2ac3-3968-43d8-a207-305f0f049660"],

Cell[BoxData["0"], "Output",
 CellChangeTimes->{{3.937533631853574*^9, 3.937533639324168*^9}, 
   3.937533696647739*^9, {3.937533775002836*^9, 3.9375337925436277`*^9}, 
   3.937535396040057*^9, 3.937958211556342*^9},
 CellLabel->"Out[85]=",ExpressionUUID->"25cb2b51-0db0-41cf-ab3b-f13dc2a98fe6"]
}, Open  ]],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "explicit", " ", "example", " ", "with", " ", "16", " ", "Fourier", " ", 
    "modes"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"u016", "[", 
     RowBox[{"t_", ",", "r_"}], "]"}], "=", 
    RowBox[{"Normal", "[", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Series", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"u0sol", "[", "r", "]"}], "/.", 
             RowBox[{"k", "->", 
              RowBox[{"n", " ", "k"}]}]}], ")"}], "-", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"u0sol", "[", "r", "]"}], "/.", 
             RowBox[{"k", "->", 
              RowBox[{
               RowBox[{"-", "n"}], " ", "k"}]}]}], ")"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"r", ",", "0", ",", "10"}], "}"}]}], "]"}], "/.", 
        RowBox[{
         TemplateBox[{"1"},
          "C"], "->", 
         RowBox[{
          RowBox[{
           RowBox[{"cu", "[", "n", "]"}], "/", "2"}], "/", "I"}]}]}], ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "1", ",", "16"}], "}"}]}], "]"}], "]"}]}], 
   ";"}]}]], "Input",
 CellChangeTimes->{{3.937535003844211*^9, 3.937535022419702*^9}, 
   3.937535082275713*^9, {3.937535133255196*^9, 3.9375351338460817`*^9}, {
   3.937536320552868*^9, 3.937536333272903*^9}},
 CellLabel->"In[86]:=",ExpressionUUID->"973ebaad-75d9-4dae-a558-ed10ce8d3df5"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Do the same for v0", "Subsection",
 CellChangeTimes->{{3.937533891188126*^9, 
  3.937533894150157*^9}},ExpressionUUID->"3be8f047-526a-4750-ae9b-\
a33f75549c4c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"v0modeorigin", "[", 
   RowBox[{"t_", ",", "r_"}], "]"}], "=", 
  RowBox[{"Normal", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Series", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"v0sol", "[", "r", "]"}], ")"}], "-", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"v0sol", "[", "r", "]"}], "/.", 
           RowBox[{"k", "->", 
            RowBox[{"-", "k"}]}]}], ")"}]}], "//", "FullSimplify"}], ",", 
       RowBox[{"{", 
        RowBox[{"r", ",", "0", ",", "10"}], "}"}]}], "]"}], "/.", 
     RowBox[{
      TemplateBox[{"1"},
       "C"], "->", 
      RowBox[{
       RowBox[{
        RowBox[{"cu", "[", "1", "]"}], "/", "2"}], "/", "I"}]}]}], "//", 
    "FullSimplify"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.937533864054957*^9, 3.9375338692556343`*^9}},
 CellLabel->"In[87]:=",ExpressionUUID->"31671a22-57a0-4cf8-9d00-8175b94f484b"],

Cell[BoxData["0"], "Output",
 CellChangeTimes->{3.937533873014616*^9, 3.937535455038415*^9, 
  3.937958211584057*^9},
 CellLabel->"Out[87]=",ExpressionUUID->"74295dde-4d35-4a47-9d31-a54beef38a86"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Note that v0 near the SSH diverges; the imaginary part is zero, as it should \
be\
\>", "Subsubsection",
 CellChangeTimes->{{3.937534145605267*^9, 
  3.937534162933148*^9}},ExpressionUUID->"071d09c5-ee05-4562-8b1e-\
ddaac78edf68"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"v0modessh", "[", 
   RowBox[{"t_", ",", "r_"}], "]"}], "=", 
  RowBox[{
   RowBox[{
    RowBox[{"Normal", "[", 
     RowBox[{"Assuming", "[", 
      RowBox[{
       RowBox[{"r", "<", "1"}], ",", 
       RowBox[{
        RowBox[{"Series", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"v0sol", "[", "r", "]"}], ")"}], "-", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"v0sol", "[", "r", "]"}], "/.", 
              RowBox[{"k", "->", 
               RowBox[{"-", "k"}]}]}], ")"}]}], "//", "Simplify"}], ",", 
          RowBox[{"{", 
           RowBox[{"r", ",", "1", ",", "0"}], "}"}]}], "]"}], "/.", 
        RowBox[{
         TemplateBox[{"1"},
          "C"], "->", 
         RowBox[{
          RowBox[{
           RowBox[{"cu", "[", "1", "]"}], "/", "2"}], "/", "I"}]}]}]}], "]"}],
      "]"}], "//", "Simplify"}], "//", "FullSimplify"}]}]], "Input",
 CellChangeTimes->{{3.937533908532453*^9, 3.937533913110858*^9}, {
  3.937533970759191*^9, 3.937534023112089*^9}},
 CellLabel->"In[88]:=",ExpressionUUID->"4694fb30-208a-4a4c-9b17-426418880be4"],

Cell[BoxData["0"], "Output",
 CellChangeTimes->{{3.937533961790429*^9, 3.9375340136416388`*^9}, 
   3.93753404520133*^9, 3.937535472837943*^9, 3.93795821160415*^9},
 CellLabel->"Out[88]=",ExpressionUUID->"bf4abab2-b67d-4430-81c1-7aececa98a4a"]
}, Open  ]],

