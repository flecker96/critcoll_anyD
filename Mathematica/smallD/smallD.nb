Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "a", " ", "direct", " ", "limit", " ", "shows", " ", "that", " ", "the", 
     " ", "result", " ", "is", " ", "non"}], "-", 
