        ";"}], "\[IndentingNewLine]", ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "r"}], "}"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
   
   RowBox[{"{", 
    RowBox[{
     RowBox[{"ListPlot3D", "[", "pListU", "]"}], ",", 
     RowBox[{"ListPlot3D", "[", "pListV", "]"}], ",", 
