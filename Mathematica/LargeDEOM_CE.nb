Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", "example", " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"alphaNow", "[", "t_", "]"}], "=", 
     RowBox[{
      RowBox[{"Sin", "[", "t", "]"}], "+", 
      RowBox[{"0.1", 
       RowBox[{"Sin", "[", 
        RowBox[{"3", "t"}], "]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"betaNow", "[", "t_", "]"}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"alphaNow", "[", "t", "]"}], ",", "t"}], "]"}], "/", "2"}], 
      "+", 
      RowBox[{
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"alphaNow", "[", "t", "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"t", ",", "2"}], "}"}]}], "]"}], "/", "2"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"replNow", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"alpha", "->", "alphaNow"}], ",", 
       RowBox[{"beta", "->", "betaNow"}], ",", 
       RowBox[{"Dim", "->", "10"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"rList", "=", 
     RowBox[{"Range", "[", 
      RowBox[{"0", ",", "1", ",", "0.05"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"tList", "=", 
     RowBox[{"Range", "[", 
      RowBox[{"0.01", ",", 
       RowBox[{"2", "Pi"}], ",", "0.05"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"plotting", " ", "result"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Monitor", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"pListU", "=", 
        RowBox[{"Flatten", "[", 
         RowBox[{
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"t", ",", "r", ",", 
              RowBox[{
               RowBox[{"UNLO", "[", 
                RowBox[{"t", ",", "r"}], "]"}], "/.", "replNow"}]}], "}"}], 
            ",", 
            RowBox[{"{", 
             RowBox[{"t", ",", "tList"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"r", ",", "rList"}], "}"}]}], "]"}], ",", "1"}], "]"}]}],
        ";", "\[IndentingNewLine]", 
       RowBox[{"pListV", "=", 
        RowBox[{"Flatten", "[", 
         RowBox[{
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"t", ",", "r", ",", 
              RowBox[{
               RowBox[{"VNLO", "[", 
                RowBox[{"t", ",", "r"}], "]"}], "/.", "replNow"}]}], "}"}], 
            ",", 
            RowBox[{"{", 
             RowBox[{"t", ",", "tList"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"r", ",", "rList"}], "}"}]}], "]"}], ",", "1"}], "]"}]}],
        ";", "\[IndentingNewLine]", 
       RowBox[{"pListia2", "=", 
        RowBox[{"Flatten", "[", 
         RowBox[{
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"t", ",", "r", ",", 
              RowBox[{
               RowBox[{"ia2NLO", "[", 
                RowBox[{"t", ",", "r"}], "]"}], "/.", "replNow"}]}], "}"}], 
            ",", 
            RowBox[{"{", 
             RowBox[{"t", ",", "tList"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"r", ",", "rList"}], "}"}]}], "]"}], ",", "1"}], "]"}]}],
        ";", "\[IndentingNewLine]", 
       RowBox[{"pListf", "=", 
        RowBox[{"Flatten", "[", 
         RowBox[{
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"t", ",", "r", ",", 
              RowBox[{
               RowBox[{"fNLO", "[", 
                RowBox[{"t", ",", "r"}], "]"}], "/.", "replNow"}]}], "}"}], 
            ",", 
            RowBox[{"{", 
             RowBox[{"t", ",", "tList"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"r", ",", "rList"}], "}"}]}], "]"}], ",", "1"}], "]"}]}],
        ";", "\[IndentingNewLine]", 
       RowBox[{"pListPsi", "=", 
        RowBox[{"Flatten", "[", 
         RowBox[{
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"t", ",", "r", ",", 
              RowBox[{
               RowBox[{"PSINLO", "[", 
                RowBox[{"t", ",", "r"}], "]"}], "/.", "replNow"}]}], "}"}], 
            ",", 
            RowBox[{"{", 
             RowBox[{"t", ",", "tList"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"r", ",", "rList"}], "}"}]}], "]"}], ",", "1"}], "]"}]}],
        ";", "\[IndentingNewLine]", 
       RowBox[{"pListPi", "=", 
        RowBox[{"Flatten", "[", 
         RowBox[{
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"t", ",", "r", ",", 
              RowBox[{
               RowBox[{"PINLO", "[", 
                RowBox[{"t", ",", "r"}], "]"}], "/.", "replNow"}]}], "}"}], 
            ",", 
            RowBox[{"{", 
             RowBox[{"t", ",", "tList"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"r", ",", "rList"}], "}"}]}], "]"}], ",", "1"}], "]"}]}],
        ";", "\[IndentingNewLine]", 
       RowBox[{"pListRicci", "=", 
