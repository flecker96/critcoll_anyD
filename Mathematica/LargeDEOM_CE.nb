   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"ordList", "=", 
     RowBox[{"{", 
      RowBox[{"2", ",", "2", ",", "3", ",", "3", ",", "2"}], "}"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"Table", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"now", "=", 
       RowBox[{
        RowBox[{"Series", "[", 
         RowBox[{
          RowBox[{"eomD", "[", 
           RowBox[{"[", "i", "]"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"Dim", ",", "Infinity", ",", 
            RowBox[{"ordList", "[", 
             RowBox[{"[", "i", "]"}], "]"}]}], "}"}]}], "]"}], "//.", 
        "replDserNLO"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Normal", "[", 
       RowBox[{
        RowBox[{"Dim", " ", 
         RowBox[{
          RowBox[{"D", "[", 
           RowBox[{"now", ",", "Dim"}], "]"}], "/", "now"}]}], "//", 
        "Simplify"}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", 
       RowBox[{"Length", "[", "eomD", "]"}]}], "}"}]}], "]"}]}]}]], "Input",
