Cell[BoxData[
 RowBox[{
  RowBox[{"dealias", "[", 
   RowBox[{"f_", ",", "Nt_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "}"}], ",", 
    RowBox[{"Re", "[", 
     RowBox[{
      SqrtBox["Nt"], 
      RowBox[{"InverseFourier", "[", 
       RowBox[{"halve", "[", 
        RowBox[{
         RowBox[{
          FractionBox["1", 
           SqrtBox[
            RowBox[{"2", "Nt"}]]], 
          RowBox[{"Fourier", "[", "f", "]"}]}], ",", "Nt"}], "]"}], "]"}]}], 
     "]"}]}], "]"}]}]], "Input",
