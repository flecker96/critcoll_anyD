Cell[CellGroupData[{

Cell["Integrate PDEs for null coordinates (u,v)", "Subsection",
 CellChangeTimes->{{3.9350448384580383`*^9, 3.935044841765587*^9}, {
  3.935120485615307*^9, 3.935120489343433*^9}, {3.935120891859625*^9, 
  3.935120893843343*^9}},ExpressionUUID->"a372679c-1394-4614-af40-\
e93b63f1f668"],

Cell[BoxData[
 RowBox[{
  RowBox[{"vBC", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"v", "[", 
       RowBox[{"Delta", ",", "x"}], "]"}], "==", "x"}], ",", 
     RowBox[{
      RowBox[{"v", "[", 
       RowBox[{"t", ",", "0"}], "]"}], "==", 
      FractionBox[
       RowBox[{"(", 
        RowBox[{"t", "-", "Delta"}], ")"}], "Delta"]}]}], "}"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.935044427768364*^9, 3.935044454056123*^9}, {
  3.9351128606057863`*^9, 3.9351128649243603`*^9}},
 CellLabel->"In[13]:=",ExpressionUUID->"a9d2ccad-2c23-41e2-a0b1-0e05859d5a0b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"vnull", "=", 
  RowBox[{"NDSolveValue", "[", 
   RowBox[{
    RowBox[{"Join", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"v", "[", 
           RowBox[{"t", ",", "x"}], "]"}], ",", "t"}], "]"}], "==", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{"(", 
           RowBox[{"x", "-", 
            RowBox[{"finterp", "[", 
             RowBox[{"t", ",", "x"}], "]"}]}], ")"}]}], "*", 
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"v", "[", 
            RowBox[{"t", ",", "x"}], "]"}], ",", "x"}], "]"}]}]}], "}"}], ",",
       "vBC"}], "]"}], ",", "v", ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "Delta"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "0", ",", "1"}], "}"}], ",", 
    RowBox[{"Method", "->", 
     RowBox[{"{", 
      RowBox[{"\"\<PDEDiscretization\>\"", "->", 
       RowBox[{"{", 
        RowBox[{"\"\<MethodOfLines\>\"", ",", 
         RowBox[{"\"\<SpatialDiscretization\>\"", "->", 
          RowBox[{"{", 
           RowBox[{"\"\<TensorProductGrid\>\"", ",", 
            RowBox[{"\"\<MinPoints\>\"", "->", "800"}]}], "}"}]}]}], "}"}]}], 
      "}"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.935044458618249*^9, 3.935044611254229*^9}, {
  3.935044676784091*^9, 3.935044678333887*^9}},
 CellLabel->"In[14]:=",ExpressionUUID->"b385e67d-d3df-4ff8-bb91-82549f5e54cc"],

