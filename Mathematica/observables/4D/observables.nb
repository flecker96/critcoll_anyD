Cell["Zero loci of U and V", "Subsection",
 CellChangeTimes->{{3.9351202750855427`*^9, 
  3.9351202820526457`*^9}},ExpressionUUID->"b5bf838e-30bd-4903-8397-\
602cc2b36d49"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Find", " ", "zeros", " ", "of", " ", "interpolating", " ", "functions"}], 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"gamutx", "=", 
    RowBox[{"ParallelTable", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"xgrid", "[", 
         RowBox[{"[", "i", "]"}], "]"}], ",", 
        RowBox[{"t", "/.", 
         RowBox[{"FindRoot", "[", 
          RowBox[{
           RowBox[{"Uinterp", "[", 
            RowBox[{"t", ",", 
             RowBox[{"xgrid", "[", 
              RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"t", ",", "0.5"}], "}"}]}], "]"}]}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "2", ",", 
        RowBox[{"nx", "+", "1"}]}], "}"}]}], "]"}]}], ";"}]}]], "Input",
