Cell[BoxData[
 RowBox[{
  RowBox[{"uBC", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"u", "[", 
       RowBox[{"Delta", ",", "x"}], "]"}], "==", 
      RowBox[{"1", "-", "x"}]}], ",", 
     RowBox[{
      RowBox[{"u", "[", 
       RowBox[{"t", ",", "1"}], "]"}], "==", 
      FractionBox[
       RowBox[{"(", 
        RowBox[{"t", "-", "Delta"}], ")"}], "Delta"]}]}], "}"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.9350446974566927`*^9, 3.935044718256165*^9}, {
  3.935112985241061*^9, 3.935113020122685*^9}, {3.935113101940118*^9, 
  3.935113117619966*^9}},
 CellLabel->"In[19]:=",ExpressionUUID->"87cdab3e-db54-4f31-a556-3e6937b3f8c3"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"unull", "=", 
  RowBox[{"NDSolveValue", "[", 
   RowBox[{
    RowBox[{"Join", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"u", "[", 
           RowBox[{"t", ",", "x"}], "]"}], ",", "t"}], "]"}], "==", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{"(", 
           RowBox[{"x", "+", 
            RowBox[{"finterp", "[", 
             RowBox[{"t", ",", "x"}], "]"}]}], ")"}]}], "*", 
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"u", "[", 
            RowBox[{"t", ",", "x"}], "]"}], ",", "x"}], "]"}]}]}], "}"}], ",",
       "uBC"}], "]"}], ",", "u", ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "Delta"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "0", ",", "1"}], "}"}], ",", 
    RowBox[{"Method", "->", 
     RowBox[{"{", 
      RowBox[{"\"\<PDEDiscretization\>\"", "->", 
       RowBox[{"{", 
        RowBox[{"\"\<MethodOfLines\>\"", ",", 
         RowBox[{"\"\<SpatialDiscretization\>\"", "->", 
          RowBox[{"{", 
           RowBox[{"\"\<TensorProductGrid\>\"", ",", 
            RowBox[{"\"\<MinPoints\>\"", "->", "800"}]}], "}"}]}]}], "}"}]}], 
      "}"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.935044721234252*^9, 3.9350447459703827`*^9}},
 CellLabel->"In[20]:=",ExpressionUUID->"d767ff14-3656-4e49-8a57-17665be7281c"],

