            RowBox[{"CASr", ",", "t"}], "]"}]}], "/.", "replXpm"}], "/.", 
         "replS02"}], "//", "FullSimplify"}], ",", 
       RowBox[{"{", " ", 
        RowBox[{
         RowBox[{
          SuperscriptBox["S", 
           TagBox[
            RowBox[{"(", 
             RowBox[{"0", ",", "1"}], ")"}],
