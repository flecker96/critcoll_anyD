       RowBox[{"g", ",", "xx"}], "]"}]}], ";", 
     RowBox[{"ig", "=", 
      RowBox[{"InverseMetric", "[", "g", "]"}]}], ";", "\[IndentingNewLine]", 
     
     RowBox[{"res", "=", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"ig", "[", 
          RowBox[{"[", 
           RowBox[{"s", ",", "i"}], "]"}], "]"}], " ", 
         RowBox[{"Ricc", "[", 
          RowBox[{"[", 
           RowBox[{"s", ",", "i"}], "]"}], "]"}]}], ",", 
