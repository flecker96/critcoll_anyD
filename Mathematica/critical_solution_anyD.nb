          RowBox[{
           RowBox[{"Chr", "[", 
            RowBox[{"[", 
             RowBox[{"i", ",", "k", ",", "m"}], "]"}], "]"}], ",", 
           RowBox[{"xx", "[", 
            RowBox[{"[", "l", "]"}], "]"}]}], "]"}], "-", 
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"Chr", "[", 
            RowBox[{"[", 
             RowBox[{"i", ",", "k", ",", "l"}], "]"}], "]"}], ",", 
           RowBox[{"xx", "[", 
            RowBox[{"[", "m", "]"}], "]"}]}], "]"}], "+", 
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Chr", "[", 
