Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
      "the", " ", "quantity", " ", "\"\<mustbezero\>\"", " ", "has", " ", 
       "to", " ", "vanish", " ", "on"}], "-", 
      RowBox[{
      "shell", " ", "and", " ", "can", " ", "be", " ", "checked", " ", 
       "case"}], "-", "by", "-", "case"}], ";", " ", 
     RowBox[{
     "it", " ", "is", " ", "lengthy", " ", "because", " ", "it", " ", "is", 
      " ", "essentially", " ", "a", " ", "combination", " ", "of", " ", 
      "first", " ", "derivatives", " ", "of", " ", "the", " ", "EOM"}], ";", 
     " ", 
     RowBox[{
      RowBox[{
      "for", " ", "some", " ", "specific", " ", "starting", " ", "points", 
       " ", "this", " ", "definition", " ", "may", " ", "become", " ", 
       "ill"}], "-", "posed"}]}], ",", " ", 
    RowBox[{"e", ".", "g", "."}], ",", " ", 
    RowBox[{
     RowBox[{
     "when", " ", "EOMKG", " ", "vanishes", " ", "due", " ", "to", " ", "the",
       " ", "input", " ", "or", " ", "the", " ", "scalar", " ", "field", " ", 
      "takes", " ", "already", " ", "a", " ", "specific", " ", "form"}], ";", 
     " ", 
     RowBox[{
     "since", " ", "the", " ", "evaluation", " ", "may", " ", "take", " ", 
      "long", " ", "this", " ", "is", " ", "commented", " ", "out", " ", "by",
       " ", "default"}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"replS02", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"Solve", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"EOMKG", "//", "FullSimplify"}], ")"}], "\[Equal]", "0"}], 
         ",", " ", 
         RowBox[{
          SuperscriptBox["S", 
