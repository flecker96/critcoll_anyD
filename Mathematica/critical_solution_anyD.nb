         RowBox[{"m", ",", "1", ",", "n"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Simplify", "[", "res", "]"}]}]}], "]"}]}], "\n", 
 RowBox[{
