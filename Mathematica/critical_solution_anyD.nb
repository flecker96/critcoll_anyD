Cell[BoxData[{
 RowBox[{
  RowBox[{"InverseMetric", "[", "g_", "]"}], ":=", 
  RowBox[{"Simplify", "[", 
   RowBox[{"Inverse", "[", "g", "]"}], "]"}]}], "\n", 
 RowBox[{
  RowBox[{"ChristoffelSymbol", "[", 
   RowBox[{"g_", ",", "xx_"}], "]"}], ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"n", ",", "ig", ",", "res"}], "}"}], ",", 
    RowBox[{
     RowBox[{"n", "=", 
      RowBox[{"Length", "[", "g", "]"}]}], ";", 
     RowBox[{"ig", "=", 
      RowBox[{"InverseMetric", "[", "g", "]"}]}], ";", "\[IndentingNewLine]", 
     
     RowBox[{"res", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "/", "2"}], ")"}], "*", 
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"ig", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "s"}], "]"}], "]"}], "*", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"-", 
               RowBox[{"D", "[", 
                RowBox[{
                 RowBox[{"g", "[", 
                  RowBox[{"[", 
                   RowBox[{"j", ",", "k"}], "]"}], "]"}], ",", 
                 RowBox[{"xx", "[", 
                  RowBox[{"[", "s", "]"}], "]"}]}], "]"}]}], "+", 
              RowBox[{"D", "[", 
               RowBox[{
                RowBox[{"g", "[", 
                 RowBox[{"[", 
                  RowBox[{"j", ",", "s"}], "]"}], "]"}], ",", 
                RowBox[{"xx", "[", 
                 RowBox[{"[", "k", "]"}], "]"}]}], "]"}], "+", 
              RowBox[{"D", "[", 
               RowBox[{
                RowBox[{"g", "[", 
                 RowBox[{"[", 
                  RowBox[{"s", ",", "k"}], "]"}], "]"}], ",", 
                RowBox[{"xx", "[", 
                 RowBox[{"[", "j", "]"}], "]"}]}], "]"}]}], ")"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"s", ",", "1", ",", "n"}], "}"}]}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", "n"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", "1", ",", "n"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"k", ",", "1", ",", "n"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Simplify", "[", "res", "]"}]}]}], "]"}]}], "\n", 
 RowBox[{
